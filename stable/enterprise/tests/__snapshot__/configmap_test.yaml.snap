should render additional audit uris when additionalResourceURIs is set:
  1: |
    apiVersion: v1
    data:
      config.yaml: |
        # Anchore Service Configuration File, mounted from a configmap
        #
        service_dir: ${ANCHORE_SERVICE_DIR}
        tmp_dir: ${ANCHORE_TMP_DIR}

        logging:
          colored_logging: false
          exception_backtrace_logging: false
          exception_diagnose_logging: false
          file_retention_rule: 10
          file_rotation_rule: 10 MB
          log_level: <ALLOW_API_CONFIGURATION>
          server_access_logging: true
          server_log_level: info
          server_response_debug_logging: false
          structured_logging: false

        server:
          max_connection_backlog: 2048
          max_wsgi_middleware_worker_count: 50
          max_wsgi_middleware_worker_queue_size: 100
          process_worker_count: 1
          ssl_cert: false
          ssl_chain: false
          ssl_enable: false
          ssl_key: false
          timeout_graceful_shutdown: false
          timeout_keep_alive: 5

        allow_awsecr_iam_auto: true
        host_id: "${ANCHORE_HOST_ID}"
        internal_ssl_verify: true
        image_analyze_timeout_seconds: 36000

        global_client_connect_timeout: ${ANCHORE_GLOBAL_CLIENT_CONNECT_TIMEOUT}
        global_client_read_timeout: ${ANCHORE_GLOBAL_CLIENT_READ_TIMEOUT}

        license_file: ${ANCHORE_LICENSE_FILE}
        auto_restart_services: false

        max_source_import_size_mb: 100
        max_import_content_size_mb: 100

        max_compressed_image_size_mb: -1

        audit:
          enabled: true
          mode: log
          verbs:
            - post
            - put
            - delete
            - patch
          resource_uris:
            - "/accounts"
            - "/accounts/{account_name}"
            - "/accounts/{account_name}/state"
            - "/accounts/{account_name}/users"
            - "/accounts/{account_name}/users/{username}"
            - "/accounts/{account_name}/users/{username}/api-keys"
            - "/accounts/{account_name}/users/{username}/api-keys/{key_name}"
            - "/accounts/{account_name}/users/{username}/credentials"
            - "/rbac-manager/roles"
            - "/rbac-manager/roles/{role_name}/members"
            - "/rbac-manager/saml/idps"
            - "/rbac-manager/saml/idps/{name}"
            - "/rbac-manager/saml/idps/{name}/user-group-mappings"
            - "/system/user-groups"
            - "/system/user-groups/{group_uuid}"
            - "/system/user-groups/{group_uuid}/roles"
            - "/system/user-groups/{group_uuid}/users"
            - "/user/api-keys"
            - "/user/api-keys/{key_name}"
            - "/user/credentials"
            - "/images"
            - "/containers"

        metrics:
          enabled: false
          auth_disabled: false

        default_admin_password: "${ANCHORE_ADMIN_PASSWORD}"
        default_admin_email: admin@myanchore

        configuration:
          api_driven_configuration_enabled: true

        keys:
          secret: "${ANCHORE_SAML_SECRET}"
          public_key_path: null
          private_key_path: null

        user_authentication:
          oauth:
            default_token_expiration_seconds: 3600
            refresh_token_expiration_seconds: 86400
          sso_require_existing_users: false
          allow_api_keys_for_saml_users: false
          max_api_key_age_days: 365
          max_api_keys_per_user: 100
          remove_deleted_user_api_keys_older_than_days: 365
          disallow_native_users: false
          log_saml_assertions: false
        credentials:
          database:
            user: "${ANCHORE_DB_USER}"
            password: "${ANCHORE_DB_PASSWORD}"
            host: "${ANCHORE_DB_HOST}"
            port: "${ANCHORE_DB_PORT}"
            name: "${ANCHORE_DB_NAME}"
            db_connect_args:
              timeout: ${ANCHORE_DB_TIMEOUT}
              ssl: false
            db_pool_size: ${ANCHORE_DB_POOL_SIZE}
            db_pool_max_overflow: ${ANCHORE_DB_POOL_MAX_OVERFLOW}

        account_gc:
          max_resource_gc_chunk: 4096
          max_deletion_threads: 4

        vex_annotation_author: <ALLOW_API_CONFIGURATION>
        object_store:
          direct_access: false

        services:
          apiext:
            enabled: true
            logging:
              colored_logging: false
              exception_backtrace_logging: false
              exception_diagnose_logging: false
              file_retention_rule: 10
              file_rotation_rule: 10 MB
              log_level: <ALLOW_API_CONFIGURATION>
              server_access_logging: true
              server_log_level: info
              server_response_debug_logging: false
              structured_logging: false
            image_content:
              remove_license_content_from_sbom_return: <ALLOW_API_CONFIGURATION>
            endpoint_hostname: ${ANCHORE_ENDPOINT_HOSTNAME}
            listen: "0.0.0.0"
            port: ${ANCHORE_PORT}
            cycle_timer_seconds: 1
            cycle_timers:
              api_key_token_cleanup: 43200
              oauth_token_cleanup: 21600
              service_heartbeat: 60
              system_config_environment_watcher: 20
              system_config_refresh_watcher: 20
            external_hostname: null
            external_port: null
            external_tls: false
            server:
              max_connection_backlog: 2048
              max_wsgi_middleware_worker_count: 50
              max_wsgi_middleware_worker_queue_size: 100
              process_worker_count: 1
              ssl_cert: false
              ssl_chain: false
              ssl_enable: false
              ssl_key: false
              timeout_graceful_shutdown: false
              timeout_keep_alive: 5

          analyzer:
            enabled: true
            analyzer_scanner_config:
              content_search:
                enabled: true
                layer_scope: squashed
                match_params: []
                regexp_match: []
              file_contents:
                enabled: true
                file_list:
                - /etc/passwd
                - /anchore_hints.json
                layer_scope: squashed
                max_file_size_kb: 1000
              malware:
                clamav:
                  db_update_enabled: true
                  enabled: <ALLOW_API_CONFIGURATION>
                  max_scan_time: 1800000
              secret_search:
                enabled: true
                layer_scope: squashed
                match_params:
                - MAXFILESIZE=10000
                - STOREONMATCH=n
                regexp_match:
                - AWS_ACCESS_KEY=(?i).*aws_access_key_id( *=+ *).*(?<![A-Z0-9])[A-Z0-9]{20}(?![A-Z0-9]).*
                - AWS_SECRET_KEY=(?i).*aws_secret_access_key( *=+ *).*(?<![A-Za-z0-9/+=])[A-Za-z0-9/+=]{40}(?![A-Za-z0-9/+=]).*
                - PRIV_KEY=(?i)-+BEGIN(.*)PRIVATE KEY-+
                - 'DOCKER_AUTH=(?i).*"auth": *".+"'
                - API_KEY=(?i).*api(-|_)key( *=+ *).*(?<![A-Z0-9])[A-Z0-9]{20,60}(?![A-Z0-9]).*
              syft:
                parallel_workers: 2
              windows:
                enabled: true



            logging:
              log_level: <ALLOW_API_CONFIGURATION>
            endpoint_hostname: ${ANCHORE_ENDPOINT_HOSTNAME}
            listen: "0.0.0.0"
            port: ${ANCHORE_PORT}
            cycle_timer_seconds: 1
            cycle_timers:
              analysis_data_disk_gc: 3600
              handle_metrics: 15
              image_analyzer: 1
              service_heartbeat: 60
              sync_clamav_db: 60
              system_config_environment_watcher: 20
              system_config_refresh_watcher: 20
            layer_cache_enable: false
            layer_cache_max_gigabytes: 0
            enable_hints: false
            enable_owned_package_filtering: true
            keep_image_analysis_tmpfiles: ${ANCHORE_KEEP_IMAGE_ANALYSIS_TMPFILES}
            external_hostname: null
            external_port: null
            external_tls: false
            server:
              max_connection_backlog: 2048
              max_wsgi_middleware_worker_count: 50
              max_wsgi_middleware_worker_queue_size: 100
              process_worker_count: 1
              ssl_cert: false
              ssl_chain: false
              ssl_enable: false
              ssl_key: false
              timeout_graceful_shutdown: false
              timeout_keep_alive: 5

          catalog:
            enabled: true
            logging:
              colored_logging: false
              exception_backtrace_logging: false
              exception_diagnose_logging: false
              file_retention_rule: 10
              file_rotation_rule: 10 MB
              log_level: <ALLOW_API_CONFIGURATION>
              server_access_logging: true
              server_log_level: info
              server_response_debug_logging: false
              structured_logging: false
            endpoint_hostname: ${ANCHORE_ENDPOINT_HOSTNAME}
            listen: "0.0.0.0"
            port: ${ANCHORE_PORT}
            account_prometheus_metrics: <ALLOW_API_CONFIGURATION>
            cycle_timer_seconds: 1
            cycle_timers:
              account_resource_cleanup: 30
              alerts_watcher: 600
              analyzer_queue: 1
              archive_tasks: 43200
              artifact_lifecycle_policy_tasks: 43200
              document_view_collection_prune_watcher: 43200
              events_gc: 43200
              handle_deployment_metrics: 300
              handle_metrics: 60
              image_gc: 60
              image_watcher: 3600
              import_gc: 60
              integration_account_association_expiration_watcher: 300
              integration_health_report_ttl_watcher: 86400
              integration_status_update_watcher: 300
              k8s_image_watcher: 150
              legacy_syft_hybrid_view_builder: 60
              notifications: 30
              policy_eval: 3600
              repo_watcher: 60
              resource_limit_notifications: 3600
              resource_metrics: 300
              runtime_inventory_image_ttl_watcher: 86400
              sbom_vuln_scan_refresh_watcher: 60
              sbom_vuln_scan_watcher: 10
              service_heartbeat: 60
              service_watcher: 15
              source_gc: 60
              source_import_gc: 60
              syft_sbom_metadata_annotations: 150
              system_config_environment_watcher: 20
              system_config_refresh_watcher: 20
              system_logs_gc: 43200
              vulnerability_scan: 14400
            event_log:
              max_retention_age_days: 180
              notification:
                enabled: false
