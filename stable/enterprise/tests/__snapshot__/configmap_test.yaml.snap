            image_gc:
              max_worker_threads: 4
            runtime_compliance:
              object_store_bucket: "runtime_compliance_check"
            import_operation_expiration_days: 7
            analysis_queue_priority: <ALLOW_API_CONFIGURATION>
            sbom_vuln_scan:
              auto_scale: true
              batch_size: 1
              pool_size: 1
            analysis_archive:
              {}
            object_store:
              compression:
                enabled: true
                min_size_kbytes: 100
              storage_driver:
                config: {}
                name: db
              verify_content_digests: true
            document_views:
              generation:
                max_document_execution_seconds: 300
                multiprocess_count: 2
                multiprocess_enabled: true
                recycle_worker_processes_count: 10
            system_logs:
              expiration_days: 730
            external_hostname: null
            external_port: null
            external_tls: false
            server:
              max_connection_backlog: 2048
              max_wsgi_middleware_worker_count: 50
              max_wsgi_middleware_worker_queue_size: 100
              process_worker_count: 1
              ssl_cert: false
