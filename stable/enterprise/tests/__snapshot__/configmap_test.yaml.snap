          analyzer:
            enabled: true
            analyzer_scanner_config:
              content_search:
                enabled: true
                layer_scope: squashed
                match_params: []
                regexp_match: []
              file_contents:
                enabled: true
                file_list:
                - /etc/passwd
                - /anchore_hints.json
                layer_scope: squashed
